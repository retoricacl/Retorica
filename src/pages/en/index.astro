  <script>
    function openModal(id) {
       const modal = document.getElementById(id);
       if (modal) {
         modal.classList.remove('hidden');
         modal.classList.add('flex', 'items-center', 'justify-center');
       }
     }

     function closeModal(id) {
       const modal = document.getElementById(id);
       if (modal) {
         modal.classList.add('hidden');
         modal.classList.remove('flex', 'items-center', 'justify-center');
       }
     }

     // Event listeners for opening modals (titles and links)
     document.getElementById('fest-link')?.addEventListener('click', (e) => {
       e.preventDefault();
       openModal('fest-modal');
     });
     document.getElementById('fest-title')?.addEventListener('click', () => openModal('fest-modal'));

     document.getElementById('party-link')?.addEventListener('click', (e) => {
       e.preventDefault();
       openModal('party-modal');
     });
     document.getElementById('party-title')?.addEventListener('click', () => openModal('party-modal'));

     document.getElementById('prom-link')?.addEventListener('click', (e) => {
       e.preventDefault();
       openModal('prom-modal');
     });
     document.getElementById('prom-title')?.addEventListener('click', () => openModal('prom-modal'));

     document.getElementById('nodo-link')?.addEventListener('click', (e) => {
       e.preventDefault();
       openModal('nodo-modal');
     });
     document.getElementById('nodo-title')?.addEventListener('click', () => openModal('nodo-modal'));

     document.getElementById('venues-link')?.addEventListener('click', (e) => {
       e.preventDefault();
       openModal('venues-modal');
     });
     document.getElementById('venues-title')?.addEventListener('click', () => openModal('venues-modal'));

     // Event listeners for closing modals
     document.getElementById('close-fest')?.addEventListener('click', () => closeModal('fest-modal'));
     document.getElementById('close-party')?.addEventListener('click', () => closeModal('party-modal'));
     document.getElementById('close-prom')?.addEventListener('click', () => closeModal('prom-modal'));
     document.getElementById('close-nodo')?.addEventListener('click', () => closeModal('nodo-modal'));
     document.getElementById('close-venues')?.addEventListener('click', () => closeModal('venues-modal'));

     // Close open modals with "Escape" key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeModal('fest-modal');
          closeModal('party-modal');
          closeModal('prom-modal');
          closeModal('nodo-modal');
          closeModal('venues-modal');
        }
      });


     // Toggle contact form
     document.getElementById('toggle-form')?.addEventListener('click', () => {
       const form = document.getElementById('contact-form');
       if (form) {
         form.style.display = form.style.display === 'none' ? 'block' : 'none';
         const btn = document.getElementById('toggle-form');
         if (btn) {
           btn.textContent = form.style.display === 'none' ? 'Show Form' : 'Close form';
         }
       }
     });

     // Toggle logos
     document.getElementById('toggle-logos')?.addEventListener('click', () => {
       const container = document.getElementById('logos-container');
       const btn = document.getElementById('toggle-logos') as HTMLButtonElement;
       if (container && btn) {
         container.style.display = container.style.display === 'none' ? 'block' : 'none';
         btn.textContent = container.style.display === 'none' ? (btn.dataset.show || '') : (btn.dataset.hide || '');
       }
     });

     // Slider functionality
     // Fest slider
     let festCurrent = 0;
     const festSlides = document.querySelectorAll('#festivales .slide');
     function showFestSlide(index) {
       festSlides.forEach(slide => slide.classList.remove('active'));
       festSlides[index].classList.add('active');
       festCurrent = index;
     }
     document.querySelector('.fest-prev')?.addEventListener('click', () => {
       const newIndex = (festCurrent - 1 + festSlides.length) % festSlides.length;
       showFestSlide(newIndex);
     });
     document.querySelector('.fest-next')?.addEventListener('click', () => {
       const newIndex = (festCurrent + 1) % festSlides.length;
       showFestSlide(newIndex);
     });

     // Party slider
     let partyCurrent = 0;
     const partySlides = document.querySelectorAll('#party .slide');
     function showPartySlide(index) {
       partySlides.forEach(slide => slide.classList.remove('active'));
       partySlides[index].classList.add('active');
       partyCurrent = index;
     }
     document.querySelector('.party-prev')?.addEventListener('click', () => {
       const newIndex = (partyCurrent - 1 + partySlides.length) % partySlides.length;
       showPartySlide(newIndex);
     });
     document.querySelector('.party-next')?.addEventListener('click', () => {
       const newIndex = (partyCurrent + 1) % partySlides.length;
       showPartySlide(newIndex);
     });

     // Prom slider
     let promCurrent = 0;
     const promSlides = document.querySelectorAll('#prom .slide');
     function showPromSlide(index) {
       promSlides.forEach(slide => slide.classList.remove('active'));
       promSlides[index].classList.add('active');
       promCurrent = index;
     }
     document.querySelector('.prom-prev')?.addEventListener('click', () => {
       const newIndex = (promCurrent - 1 + promSlides.length) % promSlides.length;
       showPromSlide(newIndex);
     });
     document.querySelector('.prom-next')?.addEventListener('click', () => {
       const newIndex = (promCurrent + 1) % promSlides.length;
       showPromSlide(newIndex);
     });

     // Nodo slider
     let nodoCurrent = 0;
     const nodoSlides = document.querySelectorAll('#nodo .slide');
     function showNodoSlide(index) {
       nodoSlides.forEach(slide => slide.classList.remove('active'));
       nodoSlides[index].classList.add('active');
       nodoCurrent = index;
     }
     document.querySelector('.nodo-prev')?.addEventListener('click', () => {
       const newIndex = (nodoCurrent - 1 + nodoSlides.length) % nodoSlides.length;
       showNodoSlide(newIndex);
     });
     document.querySelector('.nodo-next')?.addEventListener('click', () => {
       const newIndex = (nodoCurrent + 1) % nodoSlides.length;
       showNodoSlide(newIndex);
     });

    // Venues slider
    let venuesCurrent = 0;
    const venuesSlides = document.querySelectorAll('#venues .slide');
    function showVenuesSlide(index) {
      venuesSlides.forEach(slide => slide.classList.remove('active'));
      venuesSlides[index].classList.add('active');
      venuesCurrent = index;
    }
    document.querySelector('.venues-prev')?.addEventListener('click', () => {
      const newIndex = (venuesCurrent - 1 + venuesSlides.length) % venuesSlides.length;
      showVenuesSlide(newIndex);
    });
    document.querySelector('.venues-next')?.addEventListener('click', () => {
      const newIndex = (venuesCurrent + 1) % venuesSlides.length;
      showVenuesSlide(newIndex);
    });

    // Auto-play functionality for all galleries
    setInterval(() => {
      const newFestIndex = (festCurrent + 1) % festSlides.length;
      showFestSlide(newFestIndex);
    }, 4000); // 4 seconds

    setInterval(() => {
      const newPartyIndex = (partyCurrent + 1) % partySlides.length;
      showPartySlide(newPartyIndex);
    }, 4000);

    setInterval(() => {
      const newPromIndex = (promCurrent + 1) % promSlides.length;
      showPromSlide(newPromIndex);
    }, 4000);

    setInterval(() => {
      const newNodoIndex = (nodoCurrent + 1) % nodoSlides.length;
      showNodoSlide(newNodoIndex);
    }, 4000);

    setInterval(() => {
      const newVenuesIndex = (venuesCurrent + 1) % venuesSlides.length;
      showVenuesSlide(newVenuesIndex);
    }, 4000);

     // Form validation and submission
     document.getElementById('contact-form-element')?.addEventListener('submit', async function(e) {
       e.preventDefault();
       const form = e.target as HTMLFormElement;
       const formData = new FormData(form);
       const messagesDiv = document.getElementById('form-messages') as HTMLDivElement;
       const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
       const emailError = document.getElementById('email-error') as HTMLSpanElement;

       // Clear previous messages
       if (messagesDiv) messagesDiv.innerHTML = '';
       if (emailError) emailError.textContent = '';

       // Validate email
       const email = (document.getElementById('email') as HTMLInputElement).value;
       const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
       if (!emailRegex.test(email)) {
         if (emailError) emailError.textContent = 'Please enter a valid email.';
         return;
       }

       // Check required fields
       const requiredFields = ['servicio', 'name', 'email', 'message'];
       for (const field of requiredFields) {
         if (!formData.get(field)) {
           if (messagesDiv) messagesDiv.innerHTML = '<p class="text-red-500">Please complete all required fields.</p>';
           return;
         }
       }

       // Disable button
       if (submitBtn) {
         submitBtn.disabled = true;
         submitBtn.textContent = 'Sending...';
       }

       try {
          const formObject = Object.fromEntries(formData);
          const response = await fetch('/api/sendEmail', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formObject),
          });

          if (response.ok) {
            // Success
            form.style.display = 'none';
            if (messagesDiv) messagesDiv.innerHTML = '<p class="text-green-500 text-lg font-semibold">Thank you! Your message has been sent. We will get back to you soon.</p>';
          } else {
            const errorData = await response.json();
            throw new Error(errorData.message || 'Submission error');
          }
        } catch (error) {
          console.error('Form submission error:', error);
          // Error
          if (messagesDiv) messagesDiv.innerHTML = '<p class="text-red-500">There was an error sending the message. Please try again later.</p>';
        } finally {
         // Re-enable button
         if (submitBtn) {
           submitBtn.disabled = false;
           submitBtn.textContent = 'Send';
         }
       }
     });
   </script>
</Layout>
